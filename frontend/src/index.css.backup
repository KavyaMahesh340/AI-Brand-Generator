@import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&family=Space+Grotesk:wght@400;500;600;700&display=swap');
@import "tailwindcss";

/* ═══════════════════════════════════════════════════════════════════
   BLOOMBIG STUDIO — PROFESSIONAL LIGHT DESIGN SYSTEM
   Agency-grade SaaS marketing platform
   ═══════════════════════════════════════════════════════════════════ */

/* ─── Color Palette ──────────────────────────────────────────────── */
:root {
  /* Teal (primary brand) */
  --teal-50:  #f0fdfa;
  --teal-100: #ccfbf1;
  --teal-200: #99f6e4;
  --teal-300: #5eead4;
  --teal-400: #2dd4bf;
  --teal-500: #14b8a6;
  --teal-600: #0d9488;
  --teal-700: #0f766e;
  --teal-800: #115e56;
  --teal-900: #134e4a;

  /* Navy (headings, UI chrome) */
  --navy-50:  #f8fafc;
  --navy-100: #f1f5f9;
  --navy-200: #e2e8f0;
  --navy-300: #cbd5e1;
  --navy-400: #94a3b8;
  --navy-500: #64748b;
  --navy-600: #475569;
  --navy-700: #334155;
  --navy-800: #1e293b;
  --navy-900: #0f172a;

  /* Accent Coral */
  --coral-50:  #fff1f2;
  --coral-100: #ffe4e6;
  --coral-200: #fecdd3;
  --coral-300: #fda4af;
  --coral-400: #fb7185;
  --coral-500: #f43f5e;
  --coral-600: #e11d48;
  --coral-700: #be123c;

  /* Amber */
  --amber-50:  #fffbeb;
  --amber-100: #fef3c7;
  --amber-200: #fde68a;
  --amber-300: #fcd34d;
  --amber-400: #fbbf24;
  --amber-500: #f59e0b;
  --amber-600: #d97706;
  --amber-700: #b45309;

  /* Green */
  --green-50:  #f0fdf4;
  --green-100: #dcfce7;
  --green-200: #bbf7d0;
  --green-300: #86efac;
  --green-400: #4ade80;
  --green-500: #22c55e;
  --green-600: #16a34a;
  --green-700: #15803d;

  /* Purple */
  --purple-50:  #faf5ff;
  --purple-100: #f3e8ff;
  --purple-200: #e9d5ff;
  --purple-300: #d8b4fe;
  --purple-400: #c084fc;
  --purple-500: #a855f7;
  --purple-600: #9333ea;
  --purple-700: #7e22ce;

  /* ─── Semantic Tokens (Light Theme — single root) ─── */
  --bloom-primary:        var(--teal-600);
  --bloom-primary-hover:  var(--teal-700);
  --bloom-primary-light:  var(--teal-500);
  --bloom-accent:         var(--coral-500);
  --bloom-success:        var(--green-600);
  --bloom-danger:         var(--coral-600);
  --bloom-warning:        var(--amber-500);
  --bloom-info:           #3b82f6;
  --bloom-segment:        var(--purple-600);

  /* ─── Surface & Background ─── */
  --bg-base:         #f8fafc;
  --bg-surface:      #ffffff;
  --bg-card:         #ffffff;
  --bg-card-hover:   #f8fafc;
  --bg-subtle:       #f1f5f9;

  /* ─── Borders ─── */
  --border-default:  #e2e8f0;
  --border-subtle:   #f1f5f9;
  --border-focus:    var(--teal-500);

  /* ─── Text ─── */
  --text-primary:    #0f172a;
  --text-secondary:  #475569;
  --text-muted:      #94a3b8;
  --text-disabled:   #cbd5e1;

  /* ─── Shadows ─── */
  --shadow-xs:  0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-sm:  0 1px 3px 0 rgb(0 0 0 / 0.08), 0 1px 2px -1px rgb(0 0 0 / 0.06);
  --shadow-md:  0 4px 6px -1px rgb(0 0 0 / 0.07), 0 2px 4px -2px rgb(0 0 0 / 0.05);
  --shadow-lg:  0 10px 15px -3px rgb(0 0 0 / 0.07), 0 4px 6px -4px rgb(0 0 0 / 0.05);
  --shadow-card: var(--shadow-sm);

  /* ─── Radii ─── */
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --radius-xl: 20px;
  --radius-full: 9999px;
}

/* ─── Base Reset ─────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background-color: var(--bg-base);
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ─── Scrollbar ──────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: #f1f5f9; }
::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

/* ─── Global Alignment Fixes ─────────────────────────────────────── */
/* Icons inside flex rows never push text out */
svg { flex-shrink: 0; }

/* All inline-flex elements stay vertically centred */
.inline-flex, [class*="badge"], [class*="status-pill"] {
  align-items: center;
  vertical-align: middle;
}

/* Stat card number overflow guard removed - caused font clipping */


h1, h2, h3, h4, h5, h6 {
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--text-primary);
  line-height: 1.25;
}

/* ─── Page Layout ────────────────────────────────────────────────── */
.page-wrapper {
  padding: 32px 36px;
  max-width: 1400px;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
  gap: 16px;
  flex-wrap: nowrap;
}
.page-header > *:last-child {
  flex-shrink: 0;
}


.page-title {
  font-size: 26px;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.page-subtitle {
  font-size: 14px;
  color: var(--text-secondary);
  font-weight: 400;
}

/* ─── Section Labels ─────────────────────────────────────────────── */
.section-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 12px;
}

/* ─── Cards ──────────────────────────────────────────────────────── */
.saas-card {
  background: var(--bg-card);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: box-shadow 0.2s ease, border-color 0.2s ease;
}

.saas-card:hover {
  box-shadow: var(--shadow-md);
  border-color: #cbd5e1;
}

.saas-card-static {
  background: var(--bg-card);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

/* Legacy aliases used by pages */
.glass-card {
  background: var(--bg-card);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  transition: box-shadow 0.2s ease, border-color 0.2s ease;
}
.glass-card:hover {
  box-shadow: var(--shadow-md);
  border-color: #cbd5e1;
}
.glass-card-static {
  background: var(--bg-card);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.btn, button[class*="btn"], [class*="button"], [class*="badge"] {
  white-space: nowrap;
}

/* All flex containers: children never shrink to zero */
.page-header, .stat-card, .sidebar-nav-item,
.card-header, [class*="card"] > * {
  min-width: 0;
}

/* ─── Stat Cards ─────────────────────────────────────────────────── */
.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}
.stat-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}

/* ─── Buttons ────────────────────────────────────────────────────── */
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--teal-600);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 1px 3px rgba(13,148,136,0.3);
  text-decoration: none;
  white-space: nowrap;
}
.btn-primary:hover {
  background: var(--teal-700);
  box-shadow: 0 4px 10px rgba(13,148,136,0.35);
  transform: translateY(-1px);
}
.btn-primary:active { transform: translateY(0); }
.btn-primary:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none;
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--teal-50);
  color: var(--teal-700);
  border: 1px solid var(--teal-200);
  border-radius: var(--radius-md);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  text-decoration: none;
  white-space: nowrap;
}
.btn-secondary:hover {
  background: var(--teal-100);
  border-color: var(--teal-300);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}
.btn-ghost:hover {
  background: var(--bg-subtle);
  color: var(--text-primary);
  border-color: #cbd5e1;
}

.btn-danger {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 16px;
  background: var(--coral-50);
  color: var(--coral-700);
  border: 1px solid var(--coral-200);
  border-radius: var(--radius-md);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}
.btn-danger:hover {
  background: var(--coral-100);
  border-color: var(--coral-300);
}

/* ─── Form Inputs ────────────────────────────────────────────────── */
.input-field {
  width: 100%;
  padding: 10px 14px;
  background: #fff;
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  outline: none;
  transition: all 0.2s ease;
  box-shadow: var(--shadow-xs);
}
.input-field::placeholder { color: var(--text-muted); }
.input-field:focus {
  border-color: var(--teal-500);
  box-shadow: 0 0 0 3px rgba(20,184,166,0.12);
}

.input-label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

/* ─── Badges ─────────────────────────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.03em;
  border: 1px solid transparent;
}

.badge-teal   { background: var(--teal-50);   color: var(--teal-700);   border-color: var(--teal-200); }
.badge-coral  { background: var(--coral-50);  color: var(--coral-700);  border-color: var(--coral-200); }
.badge-purple { background: var(--purple-50); color: var(--purple-700); border-color: var(--purple-200); }
.badge-amber  { background: var(--amber-50);  color: var(--amber-700);  border-color: var(--amber-200); }
.badge-green  { background: var(--green-50);  color: var(--green-700);  border-color: var(--green-200); }
.badge-navy   { background: var(--navy-100);  color: var(--navy-700);   border-color: var(--navy-200); }
.badge-blue   { background: #eff6ff;          color: #1d4ed8;           border-color: #bfdbfe; }
.badge-red    { background: var(--coral-50);  color: var(--coral-700);  border-color: var(--coral-200); }

/* Status pill (for campaign status) */
.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: 12px;
  font-weight: 600;
  border: 1px solid transparent;
}
.status-active    { background: var(--green-50);  color: var(--green-700);  border-color: var(--green-200); }
.status-draft     { background: var(--amber-50);  color: var(--amber-700);  border-color: var(--amber-200); }
.status-completed { background: #eff6ff;          color: #1d4ed8;           border-color: #bfdbfe; }
.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-dot-active    { background: var(--green-500); }
.status-dot-draft     { background: var(--amber-500); }
.status-dot-completed { background: #3b82f6; }

/* ─── Progress Bar ───────────────────────────────────────────────── */
.progress-bar-track {
  width: 100%;
  height: 6px;
  background: var(--navy-100);
  border-radius: 3px;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--teal-600), var(--teal-500));
  border-radius: 3px;
  transition: width 0.6s ease;
}

/* ─── Sidebar ────────────────────────────────────────────────────── */
.sidebar {
  width: 260px;
  height: 100vh;
  background: #ffffff;
  border-right: 1px solid var(--border-default);
  display: flex;
  flex-direction: column;
  position: fixed;
  left: 0;
  top: 0;
  z-index: 100;
  box-shadow: 1px 0 0 var(--border-subtle);
}

.sidebar-nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 14px;
  min-height: 40px;
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  transition: all 0.15s ease;
  cursor: pointer;
  border: none;
  background: none;
  width: 100%;
  text-align: left;
  font-family: 'Inter', sans-serif;
  white-space: nowrap;
  overflow: hidden;
}
.sidebar-nav-item:hover {
  background: var(--teal-50);
  color: var(--teal-700);
}
.sidebar-nav-item.active {
  background: var(--teal-50);
  color: var(--teal-700);
  border: 1px solid var(--teal-100);
  font-weight: 600;
}

/* ─── Main Content ───────────────────────────────────────────────── */
.main-content {
  margin-left: 260px;
  min-height: 100vh;
  background: var(--bg-base);
}

/* ─── Score Ring ─────────────────────────────────────────────────── */
.gauge-ring {
  transform: rotate(-90deg);
  transform-origin: center;
}

/* ─── Diff View ──────────────────────────────────────────────────── */
.diff-old {
  background: var(--coral-50);
  border-left: 3px solid var(--coral-300);
  padding: 12px 16px;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}
.diff-new {
  background: var(--teal-50);
  border-left: 3px solid var(--teal-400);
  padding: 12px 16px;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

/* ─── Platform Colour Tokens ─────────────────────────────────────── */
.platform-linkedin  { color: #0A66C2; border-color: rgba(10,102,194,0.25); background: rgba(10,102,194,0.06); }
.platform-instagram { color: #C13584; border-color: rgba(193,53,132,0.25); background: rgba(193,53,132,0.06); }
.platform-tiktok    { color: #010101; border-color: rgba(1,1,1,0.15);      background: rgba(1,1,1,0.05); }
.platform-whatsapp  { color: #128C7E; border-color: rgba(18,140,126,0.25); background: rgba(18,140,126,0.06); }

/* ─── Risk colours ───────────────────────────────────────────────── */
.risk-low    { color: var(--green-600); }
.risk-medium { color: var(--amber-600); }
.risk-high   { color: var(--coral-600); }

/* ─── Score colours ──────────────────────────────────────────────── */
.score-excellent { color: var(--teal-600); }
.score-good      { color: var(--green-600); }
.score-fair      { color: var(--amber-600); }
.score-poor      { color: var(--coral-600); }

/* ─── Pin colours ────────────────────────────────────────────────── */
.pin-coral  { background: var(--coral-400); }
.pin-teal   { background: var(--teal-500); }
.pin-amber  { background: var(--amber-400); }
.pin-purple { background: var(--purple-400); }
.pin-navy   { background: var(--navy-500); }

/* ─── Gradient Text ──────────────────────────────────────────────── */
.gradient-text {
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-500) 50%, #0ea5e9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ─── Persona Bubble (Empathy Sim) ──────────────────────────────── */
.persona-bubble {
  background: var(--teal-50);
  border: 1px solid var(--teal-200);
  border-radius: var(--radius-lg);
  border-top-left-radius: 4px;
  padding: 16px 20px;
}

/* ─── Pulse / Live indicator ─────────────────────────────────────── */
.pulse-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--green-500);
  animation: pulse-glow 2.5s infinite;
}
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
  50%       { box-shadow: 0 0 0 6px rgba(34,197,94,0); }
}

/* ─── Step indicator ─────────────────────────────────────────────── */
.step-dot {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  transition: all 0.3s ease;
  flex-shrink: 0;
}
.step-dot-active  { background: var(--teal-600); color: white; box-shadow: 0 0 0 3px var(--teal-100); }
.step-dot-done    { background: var(--green-600); color: white; }
.step-dot-pending { background: var(--navy-100); color: var(--text-muted); border: 1px solid var(--border-default); }

/* ─── Gantt bars ─────────────────────────────────────────────────── */
.gantt-bar {
  height: 28px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  padding: 0 10px;
  font-size: 11px;
  font-weight: 600;
  color: white;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: opacity 0.2s;
  cursor: pointer;
}
.gantt-bar:hover { opacity: 0.85; }

/* ─── Tooltip ────────────────────────────────────────────────────── */
.tooltip { position: relative; }
.tooltip:hover::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%);
  background: var(--navy-800);
  color: #fff;
  border-radius: 6px;
  padding: 6px 10px;
  font-size: 12px;
  white-space: nowrap;
  pointer-events: none;
  z-index: 100;
}

/* ─── Skeleton / Loading ─────────────────────────────────────────── */
.skeleton {
  background: linear-gradient(90deg, #f1f5f9 0%, #e2e8f0 50%, #f1f5f9 100%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

/* ─── Animations ─────────────────────────────────────────────────── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(16px); }
  to   { opacity: 1; transform: translateX(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.96); }
  to   { opacity: 1; transform: scale(1); }
}

.animate-fadeInUp     { animation: fadeInUp 0.45s ease forwards; }
.animate-fadeIn       { animation: fadeIn 0.3s ease forwards; }
.animate-slideInRight { animation: slideInRight 0.35s ease forwards; }
.animate-scaleIn      { animation: scaleIn 0.3s ease forwards; }

/* ─── Table overrides for light theme ───────────────────────────── */
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead tr { border-bottom: 1px solid var(--border-default); background: var(--navy-50); }
.data-table thead th {
  padding: 12px 20px;
  text-align: left;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
}
.data-table tbody tr {
  border-bottom: 1px solid var(--border-subtle);
  transition: background 0.15s;
  cursor: pointer;
}
.data-table tbody tr:hover { background: var(--teal-50); }
.data-table tbody tr:last-child { border-bottom: none; }
.data-table td { padding: 14px 20px; font-size: 13px; color: var(--text-secondary); }
.data-table td:first-child { font-weight: 600; color: var(--text-primary); font-size: 14px; }

/* ─── Divider ────────────────────────────────────────────────────── */
.divider { height: 1px; background: var(--border-default); margin: 20px 0; }

/* ─── Info banner ────────────────────────────────────────────────── */
.info-banner {
  padding: 14px 16px;
  border-radius: var(--radius-md);
  background: var(--teal-50);
  border: 1px solid var(--teal-200);
  font-size: 13px;
  color: var(--teal-800);
}
.warning-banner {
  padding: 14px 16px;
  border-radius: var(--radius-md);
  background: var(--amber-50);
  border: 1px solid var(--amber-200);
  font-size: 13px;
  color: var(--amber-800);
}

/* ─── Responsive ─────────────────────────────────────────────────── */
@media (max-width: 1024px) {
  .page-wrapper { padding: 24px 24px; }
}

@media (max-width: 768px) {
  .sidebar {
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 200;
  }
  .sidebar.open { transform: translateX(0); }
  .main-content { margin-left: 0; }
  .page-wrapper { padding: 20px 16px; }
  .page-header { flex-direction: column; align-items: flex-start; }
  .mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: #fff;
    border-bottom: 1px solid var(--border-default);
    position: sticky;
    top: 0;
    z-index: 50;
  }
}

@media (min-width: 769px) {
  .mobile-header { display: none; }
  .sidebar-overlay { display: none; }
}

@media (max-width: 640px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
  .data-table { font-size: 12px; }
  .data-table td, .data-table th { padding: 10px 12px; }
}

/* ─── Sidebar overlay (mobile) ───────────────────────────────────── */
.sidebar-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15,23,42,0.4);
  z-index: 150;
  backdrop-filter: blur(2px);
}
